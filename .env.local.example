NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# 只給 server 端用，不要放到前端元件
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_if_needed

# Booking 管理後台登入密碼（只給 Vercel / server 端）
ADMIN_PASSWORD=change_me
# 建議獨立設定；未設定時會退回 BODYFIX_ADMIN_TOKEN 或 ADMIN_PASSWORD 簽署 session cookie
ADMIN_SESSION_SECRET=change_me_to_a_long_random_secret
PUBLIC_NETLIFY_ORIGIN=https://你的正式netlify網域
LOCATION_DEMAND_PUBLIC_STATUS=coming_soon
